# --- Arbitrum Sepolia ---
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# --- Keys (TESTNET dev wallet only — never commit a real .env) ---
# AGENT_PK registers the agent on-chain, is its agentWallet, and withdraws earnings.
AGENT_PK=0xYOUR_AGENT_PRIVATE_KEY
# FACILITATOR_PK relays settlement txs and pays their gas. May equal AGENT_PK.
# Whichever key this is MUST hold Arbitrum Sepolia ETH for gas.
FACILITATOR_PK=

# --- Optional LLM (falls back to a deterministic static analyzer if absent) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Deployed contract addresses (copy from contracts/deployments/arbitrum-sepolia.json) ---
IDENTITY_REGISTRY=
REPUTATION_REGISTRY=
PAYMENT_ESCROW=
USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# --- Agent ---
PUBLIC_URL=http://localhost:8787
PRICE_USDC=0.10
# Set AGENT_ID after the first registration to skip re-registering on boot.
AGENT_ID=
PORT=8787
